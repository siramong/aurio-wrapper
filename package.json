{
  "name": "aurio-sdk",
  "version": "0.2.0",
  "type": "module",
  "description": "Professional Solana SDK for Aurio token - core logic with optional React hooks",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/siramong/aurio-wrapper"
  },
  "keywords": [
    "solana",
    "aurio",
    "spl-token",
    "web3",
    "blockchain"
  ],
  "author": "",
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@solana/actions": "^1.6.0",
    "@solana/spl-memo": "^0.2.5",
    "@solana/spl-token": "^0.1.8",
    "@solana/web3.js": "^1.98.0",
    "bs58": "^6.0.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.74.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "@types/react": ">=18.0.0",
    "typescript": "^5.6.3"
  }
}

